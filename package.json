{
  "name": "vernier",
  "version": "0.1.0",
  "description": "vernier — agent-orchestration kernel: the loop is data; the step is typed; the executor is fungible; the policy is pure; the ledger is append-only.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vernier": "bin/vernier.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "NOTICE",
    "src/executors/vendor/omegacode/LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vernier": "tsx src/cli/main.ts",
    "pilot0": "tsx src/pilot0/run.ts",
    "pilot1": "tsx src/pilot1/run.ts",
    "pilot2": "tsx src/pilot2/run.ts",
    "pilot3": "tsx src/pilot3/run.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.3.0",
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk": {
      "zod": "$zod"
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
