{
  "name": "vernier",
  "version": "0.1.0",
  "description": "vernier \u2014 agent-orchestration kernel: the loop is data; the step is typed; the executor is fungible; the policy is pure; the ledger is append-only.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vernier": "bin/vernier.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "docs/walkthrough.md",
    "docs/provider-executors.md",
    "docs/safety.md",
    "examples",
    "templates",
    "NOTICE",
    "src/executors/vendor/omegacode/LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vernier": "tsx src/cli/main.ts",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package",
    "smoke:package": "node scripts/package-smoke.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
